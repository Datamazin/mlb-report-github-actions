{
  "rules": [
    {
      "id": "REMOVE_CUSTOM_VISUALS_NOT_USED",
      "name": "Remove custom visuals which are not used in the report.",
      "description": "Returns an array of custom visual names to be removed if any. To disable this rule, mark it as disabled in the base rules file.",
      "logType": "error",
      "disabled": false,
      "part": "Report",
      "test": [
        {
          "diff": [
            {
              "var": "customvis"
            },
            {
              "map": [
                { "part": "Visuals" },
                { "var": "visual.visualType" }
              ]
            }
          ]
        },
        {
          "customvis": "/publicCustomVisuals"
        },
        []
      ]
    },
    {
      "id": "REDUCE_VISIBLE_VISUALS_ON_PAGE",
      "name": "Reduce the number of visible visuals on the page",
      "description": "Reports a test fail if the rule's maximum number of visible visuals on the page is exceeded. By default the base rules file specifies 20 as the maximum, set the paramMaxVisualsPerPage parameter to change this. To disable this rule, mark it as disabled in the base rules file.",
      "logType": "warning",
      "disabled": false,
      "part": "Pages",
      "test": [
        {
          "<=": [
            {
              "count": [
                {
                  "filter": [
                    {
                      "part": "Visuals"
                    },
                    {
                      "and": [
                        {
                          "!": [
                            {
                              "var": "isHidden"
                            }
                          ]
                        },
                        {
                          "!": [
                            {
                              "in": [
                                {
                                  "var": "visual.visualType"
                                },
                                [
                                  "shape",
                                  "slicer",
                                  "actionButton",
                                  "textbox"
                                ]
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "var": "paramMaxVisualsPerPage"
            }
          ]
        },
        {
          "paramMaxVisualsPerPage": 20
        },
        true
      ]
    },
    {
      "id": "REDUCE_OBJECTS_WITHIN_VISUALS",
      "name": "Reduce the number of objects within visuals",
      "description": "Reports a test fail if the rule's maximum number of objects within visuals on a page is exceeded. An object is a data field that is assigned to a visual. By default, the base rules file specifies 12 as the maximum objects within a visual. To disable this rule, mark it as disabled in the base rules file.",
      "logType": "warning",
      "disabled": false,
      "part": "Pages",
      "test": [
        {
          "map": [
            {
              "filter": [
                {
                  "part": "Visuals"
                },
                {
                  ">": [
                    {
                      "count": [
                        {
                          "path": "$..projections[*]"
                        }
                      ]
                    },
                    12
                  ]
                }
              ]
            },
            {
              "var": "name"
            }
          ]
        },
        {},
        []
      ]
    },
    {
      "id": "REDUCE_TOPN_FILTERING_VISUALS",
      "name": "Reduce usage of TopN filtering visuals by page",
      "description": "Reports a test fail if the rule's maximum number of visuals using TopN filtering on the page is exceeded. By default the base rules file specifies 4 as the maximum, set the paramMaxTopNFilteringPerPage to change this. To disable this rule, mark it as disabled in the base rules file.",
      "logType": "error",
      "disabled": false,
      "part": "Pages",
      "test": [
        {
          "<=": [
            {
              "count": [
                {
                  "filter": [
                    {
                      "part": "Visuals"
                    },
                    {
                      "some": [
                        {
                          "var": "filterConfig.filters"
                        },
                        {
                          "==": [
                            {
                              "var": "type"
                            },
                            "TopN"
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "var": "paramMaxTopNFilteringPerPage"
            }
          ]
        },
        {
          "paramMaxTopNFilteringPerPage": 4
        },
        true
      ]
    },
    {
      "id": "REDUCE_ADVANCED_FILTERING_VISUALS",
      "name": "Reduce usage of Advanced filtering visuals by page",
      "description": "Reports a test fail if the rule's maximum number of visuals using Advanced filtering on the page is exceeded. By default, the base rules file specifies 4 as the maximum, set the paramMaxAdvancedFilteringVisualsPerPage parameter value to change this. To disable this rule, mark it as disabled in the base rules file.",
      "logType": "warning",
      "disabled": false,
      "part": "Pages",
      "test": [
        {
          "<=": [
            {
              "count": [
                {
                  "filter": [
                    {
                      "part": "Visuals"
                    },
                    {
                      "some": [
                        {
                          "var": "filterConfig.filters"
                        },
                        {
                          "==": [
                            {
                              "var": "type"
                            },
                            "Advanced"
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "var": "paramMaxAdvancedFilteringVisualsPerPage"
            }
          ]
        },
        {
          "paramMaxAdvancedFilteringVisualsPerPage": 4
        },
        true
      ]
    },
    {
      "id": "REDUCE_NUMBER_OF_PAGES",
      "name": "Reduce number of pages per report",
      "description": "Reports a test fail if the rule's maximum number of pages per report is exceeded. By default, the base rules file specifies 10 as the maximum number of pages. Set the paramMaxNumberOfPagesPerReport parameter to change this. To disable this rule, mark it as disabled in the base rules file.",
      "logType": "warning",
      "disabled": false,
      "test": [
        {
          "<=": [
            {
              "count": [
                {
                  "part": "Pages"
                }
              ]
            },
            {
              "var": "paramMaxNumberOfPagesPerReport"
            }
          ]
        },
        {
          "paramMaxNumberOfPagesPerReport": 10
        },
        true
      ]
    },
    {
      "id": "AVOID_SHOW_ITEMS_NO_DATA",
      "name": "Avoid setting 'Show items with no data' on columns",
      "description": "Returns an array of visual names which have the option 'Show items with no data' enabled on one or more columns. To disable this rule, mark it as disabled in the base rules file.",
      "logType": "warning",
      "disabled": false,
      "part": "Pages",
      "test": [
        {
          "map": [
            {
              "filter": [
                {
                  "part": "Visuals"
                },
                {
                  "==": [
                    {
                      "var": "visual.query.queryState.Category.showAll"
                    },
                    true
                  ]
                }
              ]
            },
            {
              "var": "name"
            }
          ]
        },
        {},
        []
      ]
    },
    {
      "id": "TOOLTIP_DRILLTHROUGH_HIDDEN",
      "name": "Tooltip and Drillthrough pages should be hidden",
      "description": "Reports a test fail if a page of type Tooltip or Drillthrough is visible. To disable this rule, mark it as disabled in the base rules file.",
      "logType": "error",
      "disabled": false,
      "test": [
        {
          "map": [
            {
              "filter": [
                {
                  "part": "Pages"
                },
                {
                  "and": [
                    {
                      "in": [
                        {
                          "var": "type"
                        },
                        [
                          "Tooltip",
                          "Drillthrough"
                        ]
                      ]
                    },
                    {
                      "!=": [
                        {
                          "var": "visibility"
                        },
                        "HiddenInViewMode"
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "var": "displayName"
            }
          ]
        },
        {},
        []
      ]
    },
    {
      "id": "ENSURE_THEME_COLOURS",
      "name": "Ensure charts use theme colours",
      "description": "Check that charts (excluding textboxes) avoid custom colours and use theme colours instead. To disable this rule, mark it as disabled in the base rules file.",
      "logType": "warning",
      "disabled": false,
      "part": "Pages",
      "test": [
        {
          "map": [
            {
              "filter": [
                {
                  "part": "Visuals"
                },
                {
                  "and": [
                    {
                      "!": [
                        {
                          "in": [
                            {
                              "var": "visual.visualType"
                            },
                            [
                              "textbox"
                            ]
                          ]
                        }
                      ]
                    },
                    {
                      "strcontains": [
                        {
                          "tostring": [
                            {
                              "var": ""
                            }
                          ]
                        },
                        "#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})"
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "var": "name"
            }
          ]
        },
        {},
        []
      ]
    },
    {
      "id": "ENSURE_NO_VERTICAL_SCROLL",
      "name": "Ensure pages do not scroll vertically",
      "description": "Returns an array of visible page names with a height greater than 720px. Modify the rule parameter value if a different maximum height value is required. To disable this rule, mark it as disabled in the base rules file.",
      "logType": "warning",
      "disabled": false,
      "test": [
        {
          "map": [
            {
              "filter": [
                {
                  "part": "Pages"
                },
                {
                  "and": [
                    {
                      ">": [
                        {
                          "var": "height"
                        },
                        {
                          "var": "paramMaxAllowedPageHeight"
                        }
                      ]
                    },
                    {
                      "!=": [
                        {
                          "var": "visibility"
                        },
                        "HiddenInViewMode"
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "var": "displayName"
            }
          ]
        },
        {
          "paramMaxAllowedPageHeight": 720
        },
        []
      ]
    },
    {
      "id": "ENSURE_NON_DEFAULT_TITLES",
      "name": "Ensure non-default title has been defined for all visuals",
      "description": "Better titles for each visual helps for accessibility and maintenance. Returns visuals that do not have a non-empty custom title defined.",
      "logType": "error",
      "disabled": false,
      "part": "Pages",
      "test": [
        {
          "map": [
            {
              "filter": [
                {
                  "part": "Visuals"
                },
                {
                  "and": [
                    {
                      "!": [
                        {
                          "in": [
                            {
                              "var": "visual.visualType"
                            },
                            [
                              "shape",
                              "image"
                            ]
                          ]
                        }
                      ]
                    },
                    {
                      "!": [
                        {
                          "var": "isHidden"
                        }
                      ]
                    },
                    {
                      "none": [
                        {
                          "var": "visual.visualContainerObjects.title"
                        },
                        {
                          "or": [
                            {
                              "!!": [
                                {
                                  "var": "properties.text.expr.Aggregation"
                                }
                              ]
                            },
                            {
                              "!!": [
                                {
                                  "var": "properties.text.expr.Measure"
                                }
                              ]
                            },
                            {
                              "!=": [
                                {
                                  "var": "properties.text.expr.Literal.Value"
                                },
                                "''"
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "var": "name"
            }
          ]
        },
        {},
        []
      ]
    },
    {
      "id": "ENSURE_ALTTEXT",
      "name": "Ensure alternativeText has been defined for all non-decorative visuals",
      "description": "Alt-text is required for screen readers. Returns visuals that have a tabOrder (are not decorative) but do not have alt-text defined.",
      "logType": "error",
      "disabled": false,
      "part": "Pages",
      "test": [
        {
          "map": [
            {
              "filter": [
                {
                  "part": "Visuals"
                },
                {
                  "and": [
                    {
                      "!": [
                        {
                          "in": [
                            {
                              "var": "visual.visualType"
                            },
                            [
                              "shape"
                            ]
                          ]
                        }
                      ]
                    },
                    {
                      ">=": [
                        {
                          "var": "position.tabOrder"
                        },
                        0
                      ]
                    },
                    {
                      "none": [
                        {
                          "var": "visual.visualContainerObjects.general"
                        },
                        {
                          "or": [
                            {
                              "!!": [
                                {
                                  "var": "properties.altText.expr.Aggregation"
                                }
                              ]
                            },
                            {
                              "!=": [
                                {
                                  "var": "properties.altText.expr.Literal.Value"
                                },
                                "''"
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "var": "name"
            }
          ]
        },
        {},
        []
      ]
    },
    {
      "id": "FIRST_TAB_DEFAULT",
      "name": "First tab of the report should be the default tab",
      "description": "First tab of the report should be the default tab. Checks that the activePageName in pages.json refers to the first page in pageOrder.",
      "logType": "error",
      "disabled": false,
      "part": "PagesHeader",
      "test": [
        {
          "==": [
            {
              "var": "activePageName"
            },
            {
              "var": "firstPageName"
            }
          ]
        },
        {
          "activePageName": "/activePageName",
          "firstPageName": "/pageOrder/0"
        },
        true
      ]
    },
    {
      "id": "NO_VISUAL_HEADERS_FOR_CERTAIN_VISUALS_1",
      "name": "No visual headers for Slicers, Bookmark Navigator and Page Navigator",
      "description": "Visual headers for Slicers, Bookmark Navigator and Page Navigator should be disabled because it diminishes the user experience.",
      "logType": "error",
      "disabled": false,
      "part": "Pages",
      "test": [
        {
          "map": [
            {
              "filter": [
                {
                  "part": "Visuals"
                },
                {
                  "and": [
                    {
                      "in": [
                        {
                          "var": "visual.visualType"
                        },
                        [
                          "bookmarkNavigator",
                          "pageNavigator",
                          "slicer"
                        ]
                      ]
                    },
                    {
                      "!=": [
                        {
                          "var": [
                            "visual.visualContainerObjects.visualHeader.0.properties.show.expr.Literal.Value",
                            "true"
                          ]
                        },
                        "false"
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "var": "name"
            }
          ]
        },
        {},
        []
      ]
    },
    {
      "id": "NO_VISUAL_HEADERS_FOR_CERTAIN_VISUALS_2",
      "name": "No visual headers for Text-Box, Shapes, and Buttons",
      "description": "Visual headers for Text-Box, Shapes, and Buttons should be disabled because it diminishes the user experience.",
      "logType": "error",
      "disabled": false,
      "part": "Pages",
      "test": [
        {
          "map": [
            {
              "filter": [
                {
                  "part": "Visuals"
                },
                {
                  "and": [
                    {
                      "in": [
                        {
                          "var": "visual.visualType"
                        },
                        [
                          "actionButton",
                          "shape",
                          "textbox"
                        ]
                      ]
                    },
                    {
                      "!=": [
                        {
                          "var": [
                            "visual.visualContainerObjects.visualHeader.0.properties.show.expr.Literal.Value",
                            "false"
                          ]
                        },
                        "false"
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "var": "name"
            }
          ]
        },
        {},
        []
      ]
    },
    {
      "id": "SLICER_SEARCH_INPUT_SHOULD_BE_EMPTY",
      "name": "Slicer search input should be empty",
      "description": "Slicer search input should be empty to avoid inadvertent filtering.",
      "logType": "error",
      "disabled": false,
      "part": "Pages",
      "test": [
        {
          "map": [
            {
              "filter": [
                {
                  "part": "Visuals"
                },
                {
                  "and": [
                    {
                      "in": [
                        {
                          "var": "visual.visualType"
                        },
                        [
                          "slicer"
                        ]
                      ]
                    },
                    {
                      "!!": [
                        {
                          "var": "visual.objects.general.0.properties.selfFilter"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "var": "name"
            }
          ]
        },
        {},
        []
      ]
    },
    {
      "id": "NO_VISUAL_LEVEL_FILTERS_VISIBLE_IN_FILTER_PANEL",
      "name": "No visual level filters should be visible in the filter panel",
      "description": "When the filter panel is enabled, visual level filters should be hidden from the filter pane in view mode. Only page level and report level filters should be visible in the filter panel. Returns an array of visual names that have one or more visual level filters not hidden from view mode.",
      "logType": "error",
      "disabled": false,
      "part": "Report",
      "test": [
        {
          "if": [
            {
              "==": [
                {
                  "var": "outspacePaneVisible"
                },
                "true"
              ]
            },
            {
              "map": [
                {
                  "filter": [
                    {
                      "part": "Visuals"
                    },
                    {
                      "some": [
                        {
                          "var": "filterConfig.filters"
                        },
                        {
                          "!=": [
                            {
                              "var": "isHiddenInViewMode"
                            },
                            true
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "var": "name"
                }
              ]
            },
            []
          ]
        },
        {
          "outspacePaneVisible": "/objects/outspacePane/0/properties/visible/expr/Literal/Value"
        },
        []
      ]
    },
    {
      "id": "RULE_TEMPLATE",
      "name": "Rule Template",
      "description": "Rule template",
      "disabled": true,
      "logType": "warning",
      "test": [
        true,
        {},
        true
      ]
    }
  ]
}
